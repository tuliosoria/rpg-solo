{
  "name": "varginha-terminal-1996",
  "version": "0.1.0",
  "private": true,
  "description": "A narrative puzzle game about the 1996 Varginha UFO incident in Brazil.",
  "author": {
    "name": "Varginha Terminal 1996 contributors",
    "email": "dev@varginha1996.com"
  },
  "main": "electron/main.js",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run --configLoader runner",
    "test:watch": "vitest --configLoader runner",
    "test:coverage": "vitest run --configLoader runner --coverage",
    "typecheck": "next typegen && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"app/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx}\"",
    "validate-story": "node scripts/validate-story.js",
    "validate-enhanced": "node scripts/validate-enhanced-story.js",
    "analyze-story": "node scripts/analyze-story.js",
    "generate-report": "node scripts/generate-report.js",
    "shrink-story": "node scripts/shrink_and_spice_story.js",
    "validate-fundamentals": "node scripts/story_validator.js",
    "electron:dev": "electron .",
    "electron:build": "next build && electron-builder --config electron-builder.yml --win --mac --linux"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "steamworks.js": "^0.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@next/bundle-analyzer": "^16.1.6",
    "@next/eslint-plugin-next": "^16.1.4",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.7",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "26.1.0",
    "playwright": "^1.58.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.53.1",
    "vitest": "^4.0.17"
  }
}
